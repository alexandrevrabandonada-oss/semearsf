    "done": "npm run verify && npm run snapshot"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.97.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.8.2",
    "tailwindcss": "^3.4.17"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.21",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "postcss": "^8.5.6",
    "typescript": "^5.9.3",
    "vite": "^7.1.3"
  }
}
