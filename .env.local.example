# Configuração de Ambiente (SEMEAR PWA)
# Copie este arquivo para .env.local e preencha os valores

# --- FRONTEND (Exposto ao Browser - SEMPRE use prefixo VITE_) ---
VITE_PROJECT_NAME="SEMEAR PWA"
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_VAPID_PUBLIC_KEY=

# --- SCRIPTS / BACKEND (Protegido - NÃO use VITE_) ---
# Estas variáveis são usadas apenas em tools/ ou Edge Functions.
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_PROJECT_REF=   # Usado por scripts (ex: npm run db:types:remote)
# INGEST_API_KEY=
# VAPID_PRIVATE_KEY=

# NOTA: Este projeto utiliza Vite. 
# Variáveis com prefixo NEXT_PUBLIC_* NÃO devem ser usadas e serão reportadas pelo env:doctor.
